[global]
type=global
user_agent=H248-SIP-Gateway-Lab-PBX
endpoint_identifier_order=ip,username,anonymous

[transport-udp]
type=transport
protocol=udp
bind=${PBX_BIND_IP}:${PBX_SIP_PORT}
local_net=${PBX_LOCAL_NET}
allow_reload=no

; Authenticated softphone extension 6001.
[6001]
type=endpoint
transport=transport-udp
context=lab-users
disallow=all
allow=alaw
allow=ulaw
auth=6001-auth
aors=6001
callerid=Lab 6001 <6001>
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes
dtmf_mode=rfc4733
timers=no

[6001-auth]
type=auth
auth_type=userpass
username=6001
password=${EXTENSION_6001_PASSWORD}

[6001]
type=aor
max_contacts=2
remove_existing=yes
qualify_frequency=30
qualify_timeout=3.0

; Authenticated softphone extension 6002.
[6002]
type=endpoint
transport=transport-udp
context=lab-users
disallow=all
allow=alaw
allow=ulaw
auth=6002-auth
aors=6002
callerid=Lab 6002 <6002>
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes
dtmf_mode=rfc4733
timers=no

[6002-auth]
type=auth
auth_type=userpass
username=6002
password=${EXTENSION_6002_PASSWORD}

[6002]
type=aor
max_contacts=2
remove_existing=yes
qualify_frequency=30
qualify_timeout=3.0

; IP-authenticated SIP trunk toward the H.248 interworking gateway.
[h248-gateway]
type=endpoint
transport=transport-udp
context=from-h248-gateway
disallow=all
allow=alaw
aors=h248-gateway
from_user=asterisk-lab
from_domain=${PBX_BIND_IP}
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes
dtmf_mode=rfc4733
trust_id_inbound=yes
send_pai=yes
timers=no

[h248-gateway]
type=aor
contact=sip:${GATEWAY_SIP_IP}:${GATEWAY_SIP_PORT}
qualify_frequency=30
qualify_timeout=3.0

[h248-gateway-identify]
type=identify
endpoint=h248-gateway
match=${GATEWAY_SIP_IP}
